{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "rewriteRelativeImportExtensions": true,
    "baseUrl": ".", // This is the "root" for your paths
    "paths": {
      // Mapping the folder exactly
      "@shared/types": [
        "shared/types.ts"
      ],
      // Mapping everything in the folder
      "@shared/*": [
        "shared/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}